# Build context is the zpodsdk_builder/ directory (see `just zpodsdk-update`).
FROM python:3.12-slim AS base
COPY --from=ghcr.io/astral-sh/uv:0.10 /uv /usr/local/bin/uv
ENV UV_LINK_MODE=copy UV_COMPILE_BYTECODE=1 UV_PROJECT_ENVIRONMENT=/opt/venv
ENV PATH="/opt/venv/bin:${PATH}"
WORKDIR /zpodcore/zpodsdk_builder
ENV PYTHONPATH=/zpodcore/zpodsdk_builder
COPY pyproject.toml uv.lock /zpodcore/zpodsdk_builder/
RUN uv sync --frozen --no-dev
CMD ["tail", "-f", "/dev/null"]

# PROD
FROM base AS production
COPY . /zpodcore/zpodsdk_builder
